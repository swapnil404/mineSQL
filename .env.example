# mineSQL — copy this to .env and customize before running docker compose
#
#   cp .env.example .env
#

# Postgres wire server host port (psql connects here)
MINESQL_PORT=5433

# Chat server host port (Minecraft /sql commands)
MINESQL_CHAT_PORT=5456

# Minecraft game host port (Minecraft client connects here)
MINECRAFT_GAME_PORT=25565

# Minecraft plugin TCP host port (engine connects here in dev mode)
MINECRAFT_PLUGIN_PORT=25576

# Minecraft plugin address (dev mode: engine connects here)
MINESQL_MINECRAFT_ADDR=localhost:25576
