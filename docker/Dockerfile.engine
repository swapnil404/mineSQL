FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 go build -o /minesql ./cmd/minesql

FROM alpine:3.20

RUN apk add --no-cache ca-certificates
COPY --from=builder /minesql /usr/local/bin/minesql

EXPOSE 5433

ENTRYPOINT ["/usr/local/bin/minesql"]
